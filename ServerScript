local function unequipAllClasses(player)
	local knifeClone = player.Character:FindFirstChild("PlayersKnife") or player.Backpack:FindFirstChild("PlayersKnife")
	if knifeClone then
		local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
		knifeClone:Destroy()
		humanoid.WalkSpeed = 16
		humanoid.JumpPower = 50
	end
	local data = player:FindFirstChild("Data")
	if not data then
		return
	end

	local equippedValues = {
		data:FindFirstChild("Equipped"),
		data:FindFirstChild("NormalClassEquipped"),
		data:FindFirstChild("JumperClassEquipped"),
		data:FindFirstChild("SlasherClassEquipped"),
	}

	for _, equippedValue in equippedValues do
		if equippedValue and equippedValue:IsA("IntValue") then
			equippedValue.Value = 0
		end
	end
end




